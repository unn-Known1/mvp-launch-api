# Terraform variables example file
# Copy this to terraform.tfvars and fill in the values
#
# SECURITY NOTE: Never commit actual secrets to version control.
# Use one of these approaches:
#   1. Use environment variables: terraform apply -var="db_password=$DB_PASSWORD"
#   2. Use AWS Secrets Manager references in terraform
#   3. Use a .tfvars file that is excluded from version control (.gitignore it)
#   4. For CI/CD, use AWS SSM Parameter Store or Secrets Manager
#
# Example for CI/CD with environment variable:
#   terraform apply -var-file=terraform.tfvars.staging -var="db_password=$DB_PASSWORD"

aws_region = "us-east-1"
environment = "staging"
project_name = "mvp-launch"

# Database
# IMPORTANT: Use a strong password. In production, pass via environment variable:
#   export TF_VAR_db_password="your-secure-password"
#   terraform apply -var="db_password=$TF_VAR_db_password"
db_instance_class = "db.t3.micro"
db_name = "mvplaunch"
db_username = "admin"
db_password = "REPLACE_WITH_SECURE_PASSWORD_OR_USE_ENV_VAR"  # DO NOT commit real password

# ECS
ecs_task_cpu = 256
ecs_task_memory = 512
ecs_desired_count = 1

# S3 bucket for Terraform state (existing bucket)
# terraform {
#   backend "s3" {
#     bucket         = "your-terraform-state-bucket"
#     key            = "mvp-launch/terraform.tfstate"
#     region         = "us-east-1"
#     encrypt        = true
#     dynamodb_table = "your-terraform-locks"
#   }
# }
