# Production environment variables
aws_region = "us-east-1"
environment = "production"
project_name = "mvp-launch"

# Database
db_instance_class = "db.t3.medium"
db_name = "mvplaunch"
db_username = "admin"
# NOTE: db_password must be provided via -var="db_password=VALUE" at runtime

# ECS
ecs_task_cpu = 1024
ecs_task_memory = 2048
ecs_desired_count = 2

# Datadog (optional - leave empty to skip Datadog setup)
datadog_api_key = ""
datadog_site = "datadoghq.com"
